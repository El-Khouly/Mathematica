 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"len", "=", "100000"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"x", "=", 
     RowBox[{"Take", "[", 
      RowBox[{"key", ",", "len"}], "]"}]}], ";"}], "   ", 
   RowBox[{"(*", 
    RowBox[{
    "only", " ", "first", " ", "1000", " ", "elements", " ", "from", " ", 
     "key"}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"c", "=", "1.2"}], ";"}], "   ", 
