      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"x", "[", 
          RowBox[{"[", "j", "]"}], "]"}], " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"j", " ", "c"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "len"}], "}"}]}], "]"}], "]"}]}], ";"}], 
   "\n", 
