Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"1", ")"}], " ", "Generate", " ", "S"}], "-", "boxes"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"asconSBoxes", "=", 
     RowBox[{"GenerateSBoxesFromStream", "[", 
      RowBox[{"key", ",", "32", ",", "1000"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"2", ")"}], " ", "Evaluate", " ", "each", " ", "S"}], "-", 
     "box"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rawEvals", "=", 
     RowBox[{"EvalSbox2", "/@", "asconSBoxes"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"3", ")"}], " ", 
      RowBox[{"Normalize", ":", 
       RowBox[{
       "convert", " ", "list", " ", "of", " ", "rules", " ", "with", " ", 
        "string", " ", "values"}]}]}], "->", 
     RowBox[{"Association", " ", "with", " ", "numeric", " ", "values"}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"normalizeEval", "[", "eval_", "]"}], ":=", 
     RowBox[{"Association", "@", 
      RowBox[{"KeyValueMap", "[", 
       RowBox[{
        RowBox[{"Function", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"k", ",", "v"}], "}"}], ",", 
          RowBox[{
           RowBox[{"ToString", "[", "k", "]"}], "->", 
           RowBox[{"Quiet", "@", 
            RowBox[{"Check", "[", 
             RowBox[{
              RowBox[{"ToExpression", "[", "v", "]"}], ",", "v"}], 
             "]"}]}]}]}], "]"}], ",", 
        RowBox[{"Association", "[", "eval", "]"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"numericEvals", "=", 
     RowBox[{"normalizeEval", "/@", "rawEvals"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"4", ")"}], " ", "Pair", " ", "S"}], "-", 
     RowBox[{"box", " ", "with", " ", "its", " ", "evaluation"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"paired", "=", 
     RowBox[{"MapThread", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<SBox\>\"", "->", "#1"}], ",", 
          RowBox[{"\"\<Eval\>\"", "->", "#2"}]}], "|>"}], "&"}], ",", 
       RowBox[{"{", 
        RowBox[{"asconSBoxes", ",", "numericEvals"}], "}"}]}], "]"}]}], ";"}],
    "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"5", ")"}], " ", "Filter", " ", "by", " ", "multiple", " ", 
     "conditions"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"good", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"paired", ",", 
       RowBox[{"Function", "[", 
        RowBox[{"p", ",", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"e", "=", 
             RowBox[{"p", "[", "\"\<Eval\>\"", "]"}]}], "}"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"e", "[", "\"\<nonLin\>\"", "]"}], ">", "8"}], "&&", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"e", "[", "\"\<SAC\>\"", "]"}], ">=", "0.45"}], "&&", 
            RowBox[{
             RowBox[{"e", "[", "\"\<SAC\>\"", "]"}], "<=", "0.55"}], "&&", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"e", "[", "\"\<BIC\>\"", "]"}], ">=", "0.0"}], "&&", 
            RowBox[{
             RowBox[{"e", "[", "\"\<BIC\>\"", "]"}], "<=", "0.5"}], "&&", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"e", "[", "\"\<LAP\>\"", "]"}], "<=", "0.25"}], "&&", 
            RowBox[{
             RowBox[{"e", "[", "\"\<DAP\>\"", "]"}], "<=", "0.25"}]}]}], " ", 
          "]"}]}], "]"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"6", ")"}], " ", "Output", " ", "results"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Strong S-boxes found: \>\"", ",", 
      RowBox[{"Length", "[", "good", "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<S-box \>\"", ",", "i", ",", "\"\<: \>\"", ",", 
        RowBox[{"good", "[", 
         RowBox[{"[", 
          RowBox[{"i", ",", "\"\<SBox\>\""}], "]"}], "]"}], ",", 
        "\"\<  nonLin = \>\"", ",", 
        RowBox[{"good", "[", 
         RowBox[{"[", 
          RowBox[{"i", ",", "\"\<Eval\>\"", ",", "\"\<nonLin\>\""}], "]"}], 
         "]"}], ",", "\"\<  SAC = \>\"", ",", 
