Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", "SerialRandomnessTest", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"serialResult", "=", 
     RowBox[{"N", "@", 
      RowBox[{
       RowBox[{"ResourceFunction", "[", "\"\<SerialRandomnessTest\>\"", "]"}],
        "[", 
       RowBox[{"key", ",", "\"\<TestStatistic\>\""}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"serialPValue", "=", 
     RowBox[{"N", "@", 
      RowBox[{
       RowBox[{"ResourceFunction", "[", "\"\<SerialRandomnessTest\>\"", "]"}],
        "[", 
       RowBox[{"key", ",", "\"\<PValue\>\""}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Serial Randomness Test:\>\"", "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  Test Statistic: \>\"", ",", "serialResult"}], "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  P-Value: \>\"", ",", "serialPValue"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"serialPValue", ">", "0.05"}], ",", 
      RowBox[{
      "Print", "[", "\"\<  Result: Good randomness (p-value > 0.05)\>\"", 
       "]"}], ",", 
      RowBox[{
      "Print", "[", 
       "\"\<  Result: Bad randomness (p-value \[LessEqual] 0.05)\>\"", 
       "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
