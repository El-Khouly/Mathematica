                "]"}], "]"}], "]"}]}]}], "]"}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"nonLin", "=", 
       RowBox[{"TextString", "[", "nonLin", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"SACRes2D", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{"0", ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "sboxBitCount"}], "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "sboxBitCount"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"calBitVal", "[", 
        RowBox[{"m_", ",", "n_", ",", "testVal_"}], "]"}], ":=", 
       RowBox[{"BitAnd", "[", 
        RowBox[{
         RowBox[{"IntegerPart", "[", 
          RowBox[{"testVal", "/", 
           RowBox[{"(", 
            RowBox[{"2", "^", "n"}], ")"}]}], "]"}], ",", "1"}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"m", "=", "0"}], ",", 
        RowBox[{"m", "<", "sboxBitCount"}], ",", 
        RowBox[{"m", "++"}], ",", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"i", "=", "0"}], ",", 
          RowBox[{"i", "<=", 
           RowBox[{
            RowBox[{"Length", "[", "sbox", "]"}], "-", "1"}]}], ",", 
          RowBox[{"i", "++"}], ",", 
          RowBox[{"For", "[", 
           RowBox[{
            RowBox[{"n", "=", "0"}], ",", 
            RowBox[{"n", "<", "sboxBitCount"}], ",", 
            RowBox[{"n", "++"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"SACRes2D", "[", 
               RowBox[{"[", 
                RowBox[{"m", "+", "1"}], "]"}], "]"}], "[", 
              RowBox[{"[", 
               RowBox[{"n", "+", "1"}], "]"}], "]"}], "+=", 
             RowBox[{"calBitVal", "[", 
              RowBox[{"m", ",", "n", ",", 
               RowBox[{"BitXor", "[", 
                RowBox[{
                 RowBox[{"sbox", "[", 
                  RowBox[{"[", 
                   RowBox[{"i", "+", "1"}], "]"}], "]"}], ",", 
                 RowBox[{"sbox", "[", 
                  RowBox[{"[", 
                   RowBox[{
                    RowBox[{"BitXor", "[", 
                    RowBox[{"i", ",", 
                    RowBox[{"2", "^", "m"}]}], "]"}], "+", "1"}], "]"}], 
                  "]"}]}], "]"}]}], "]"}]}]}], "]"}]}], "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"SAC", "=", 
       RowBox[{"TextString", "[", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"Total", "[", 
           RowBox[{"SACRes2D", "/", 
            RowBox[{"(", 
             RowBox[{"2", "^", "sboxBitCount"}], ")"}]}], "]"}], "]"}], "/", 
         RowBox[{"sboxBitCount", "^", "2"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"--", 
        RowBox[{"-", 
         RowBox[{"FIXED", ":", 
          RowBox[{
           RowBox[{
           "Differential", " ", "Approximation", " ", "Probability", " ", 
            RowBox[{
             RowBox[{"(", "DAP", ")"}], "--"}]}], "-"}]}]}]}], "*)"}], 
      RowBox[{"DAP", "=", "0"}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"a", "=", "1"}], ",", 
        RowBox[{"a", "<", 
         RowBox[{"2", "^", "sboxBitCount"}]}], ",", 
        RowBox[{"a", "++"}], ",", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"b", "=", "0"}], ",", 
          RowBox[{"b", "<", 
           RowBox[{"2", "^", "sboxBitCount"}]}], ",", 
          RowBox[{"b", "++"}], ",", 
          RowBox[{
           RowBox[{"count", "=", 
            RowBox[{"Count", "[", 
             RowBox[{
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"BitXor", "[", 
                 RowBox[{
                  RowBox[{"sbox", "[", 
                   RowBox[{"[", 
                    RowBox[{"x", "+", "1"}], "]"}], "]"}], ",", 
                  RowBox[{"sbox", "[", 
                   RowBox[{"[", 
                    RowBox[{
                    RowBox[{"BitXor", "[", 
                    RowBox[{"x", ",", "a"}], "]"}], "+", "1"}], "]"}], 
                   "]"}]}], "]"}], ",", 
                RowBox[{"{", 
                 RowBox[{"x", ",", "0", ",", 
                  RowBox[{
                   RowBox[{"2", "^", "sboxBitCount"}], "-", "1"}]}], "}"}]}], 
               "]"}], ",", "b"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"DAP", "=", 
            RowBox[{"Max", "[", 
             RowBox[{"DAP", ",", 
              RowBox[{"count", "/", 
               RowBox[{"2", "^", "sboxBitCount"}]}]}], "]"}]}], ";"}]}], 
         "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"DAP", "=", 
       RowBox[{"TextString", "[", "DAP", "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
         RowBox[{"--", 
          RowBox[{"-", "Corrected"}]}], " ", "Linear", " ", "Approximation", 
         " ", "Probability", " ", 
         RowBox[{
          RowBox[{"(", "LAP", ")"}], "--"}]}], "-"}], "*)"}], 
      RowBox[{"LAP", "=", "0"}], ";", "\n", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"a", "=", "1"}], ",", 
        RowBox[{"a", "<", 
         RowBox[{"2", "^", "sboxBitCount"}]}], ",", 
        RowBox[{"a", "++"}], ",", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"b", "=", "0"}], ",", 
          RowBox[{"b", "<", 
           RowBox[{"2", "^", "sboxBitCount"}]}], ",", 
          RowBox[{"b", "++"}], ",", 
          RowBox[{
           RowBox[{"parity", "=", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"-", "1"}], ")"}], "^", 
               RowBox[{"(", 
                RowBox[{"BitAnd", "[", 
                 RowBox[{
                  RowBox[{"BitXor", "[", 
                   RowBox[{
                    RowBox[{"Dot", "[", 
                    RowBox[{
                    RowBox[{"IntegerDigits", "[", 
                    RowBox[{"a", ",", "2", ",", "sboxBitCount"}], "]"}], ",", 
                    RowBox[{"IntegerDigits", "[", 
                    RowBox[{"x", ",", "2", ",", "sboxBitCount"}], "]"}]}], 
                    "]"}], ",", 
                    RowBox[{"Dot", "[", 
                    RowBox[{
                    RowBox[{"IntegerDigits", "[", 
                    RowBox[{"b", ",", "2", ",", "sboxBitCount"}], "]"}], ",", 
                    RowBox[{"IntegerDigits", "[", 
                    RowBox[{
                    RowBox[{"sbox", "[", 
                    RowBox[{"[", 
                    RowBox[{"x", "+", "1"}], "]"}], "]"}], ",", "2", ",", 
                    "sboxBitCount"}], "]"}]}], "]"}]}], "]"}], ",", "1"}], 
                 "]"}], ")"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "0", ",", 
                RowBox[{
                 RowBox[{"2", "^", "sboxBitCount"}], "-", "1"}]}], "}"}]}], 
             "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"val", "=", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"Total", "[", "parity", "]"}], "]"}], "/", 
             RowBox[{"(", 
              RowBox[{"2", "^", "sboxBitCount"}], ")"}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"LAP", "=", 
            RowBox[{"Max", "[", 
             RowBox[{"LAP", ",", 
              RowBox[{"val", "/", "2"}]}], "]"}]}], ";"}]}], "  ", 
         RowBox[{"(*", 
          RowBox[{"normalize", " ", "to", " ", "probability", " ", "space"}], 
          "*)"}], "]"}]}], "]"}], ";", "\n", 
      RowBox[{"LAP", "=", 
       RowBox[{"TextString", "[", "LAP", "]"}]}], ";", "\[IndentingNewLine]", 
      "\n", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
         RowBox[{"--", 
          RowBox[{"-", "Corrected"}]}], " ", "Bit", " ", "Independence", " ", 
         "Criterion", " ", 
         RowBox[{
          RowBox[{"(", "BIC", ")"}], "--"}]}], "-"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"bitCorr", "=", 
       RowBox[{"{", "}"}]}], ";", "\n", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", 
        RowBox[{"i", "<=", "sboxBitCount"}], ",", 
        RowBox[{"i", "++"}], ",", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"j", "=", 
           RowBox[{"i", "+", "1"}]}], ",", 
          RowBox[{"j", "<=", "sboxBitCount"}], ",", 
          RowBox[{"j", "++"}], ",", 
          RowBox[{
           RowBox[{"AppendTo", "[", 
            RowBox[{"bitCorr", ",", 
             RowBox[{"Abs", "[", 
              RowBox[{"Correlation", "[", 
               RowBox[{
                RowBox[{"sboxBitLvlsList", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], ",", 
                RowBox[{"sboxBitLvlsList", "[", 
                 RowBox[{"[", "j", "]"}], "]"}]}], "]"}], "]"}]}], "]"}], 
           ";"}]}], "]"}]}], "]"}], ";", "\n", 
      RowBox[{"BIC", "=", 
       RowBox[{"TextString", "[", 
        RowBox[{"Mean", "[", "bitCorr", "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<nonLin\>\"", "->", "nonLin"}], ",", 
         RowBox[{"\"\<SAC\>\"", "->", "SAC"}], ",", 
         RowBox[{"\"\<BIC\>\"", "->", "BIC"}], ",", 
         RowBox[{"\"\<LAP\>\"", "->", "LAP"}], ",", 
         RowBox[{"\"\<DAP\>\"", "->", "DAP"}]}], "}"}], "]"}]}], ")"}]}], 
   "\n", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ASCONsbox", "=", 
     RowBox[{"{", 
      RowBox[{
      "4", ",", "11", ",", "31", ",", "20", ",", "26", ",", "21", ",", "9", 
       ",", "2", ",", "27", ",", "5", ",", "8", ",", "18", ",", "29", ",", 
       "3", ",", "6", ",", "28", ",", "30", ",", "19", ",", "7", ",", "14", 
       ",", "0", ",", "13", ",", "17", ",", "24", ",", "16", ",", "12", ",", 
       "1", ",", "25", ",", "22", ",", "10", ",", "15", ",", "23"}], "}"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"result", "=", 
     RowBox[{"EvalSbox2", "[", "ASCONsbox", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\\nResult (new Eval function): \>\"", ",", "result"}], 
     "]"}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.970723818379314*^9, 3.9707238494395027`*^9}, {
