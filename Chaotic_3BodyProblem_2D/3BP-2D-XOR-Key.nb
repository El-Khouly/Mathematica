Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"GenerateSBoxesFromStream", "[", 
     RowBox[{"bitstream_List", ",", "boxLength_Integer", ",", 
      RowBox[{"count_Integer", ":", "3"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "bitsPerEntry", ",", "totalBits", ",", "chunks", ",", "makeSBox", ",", 
        "sboxes"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{"Bits", " ", "needed", " ", "per", " ", "entry", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"e", ".", "g", ".", "5"}], " ", "bits", " ", "for", " ", 
           "32"}], "-", 
          RowBox[{"entry", " ", "S"}], "-", "box"}], ")"}]}], "*)"}], 
      RowBox[{
       RowBox[{"bitsPerEntry", "=", 
        RowBox[{"Ceiling", "[", 
         RowBox[{"Log2", "[", "boxLength", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"totalBits", "=", 
        RowBox[{"boxLength", "*", "bitsPerEntry"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "bitstream", "]"}], "<", 
          RowBox[{"count", "*", "totalBits"}]}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"$Failed", ",", "Module"}], "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Helper", ":", 
         RowBox[{
          RowBox[{"convert", " ", "bit", " ", "chunk", " ", "to", " ", "S"}], 
          "-", "box"}]}], "*)"}], 
       RowBox[{
        RowBox[{"makeSBox", "[", "bits_", "]"}], ":=", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"partitioned", ",", "decimals", ",", "unique"}], "}"}], 
          ",", 
          RowBox[{
           RowBox[{"partitioned", "=", 
            RowBox[{"Partition", "[", 
             RowBox[{"bits", ",", "bitsPerEntry"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"decimals", "=", 
            RowBox[{
             RowBox[{
              RowBox[{"FromDigits", "[", 
               RowBox[{"#", ",", "2"}], "]"}], "&"}], "/@", "partitioned"}]}],
            ";", "\[IndentingNewLine]", 
           RowBox[{"unique", "=", 
            RowBox[{"DeleteDuplicates", "[", "decimals", "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Length", "[", "unique", "]"}], "==", "boxLength"}], 
             ",", "unique", ",", 
             RowBox[{"Join", "[", 
              RowBox[{"unique", ",", 
               RowBox[{"Complement", "[", 
                RowBox[{
                 RowBox[{"Range", "[", 
                  RowBox[{"0", ",", 
                   RowBox[{"boxLength", "-", "1"}]}], "]"}], ",", "unique"}], 
                "]"}]}], "]"}]}], "]"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "Slice", " ", "stream", " ", "into", " ", "chunks", " ", "and", " ", 
