Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"len", "=", "100000"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"x", "=", 
     RowBox[{"Take", "[", 
      RowBox[{"key", ",", "len"}], "]"}]}], ";"}], "   ", 
   RowBox[{"(*", 
    RowBox[{
    "only", " ", "first", " ", "1000", " ", "elements", " ", "from", " ", 
     "key"}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"c", "=", "0.8"}], ";"}], "   ", 
   RowBox[{"(*", 
    RowBox[{"fixed", " ", "constant", " ", "for", " ", "reproducibility"}], 
    "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p", "=", 
     RowBox[{"Accumulate", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"x", "[", 
          RowBox[{"[", "j", "]"}], "]"}], " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"j", " ", "c"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "len"}], "}"}]}], "]"}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"q", "=", 
     RowBox[{"Accumulate", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"x", "[", 
          RowBox[{"[", "j", "]"}], "]"}], " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"j", " ", "c"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "len"}], "}"}]}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", "\[IndentingNewLine]", "\n", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"p", ",", "q"}], "}"}], "]"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", 
        RowBox[{"Thickness", "[", "0.001", "]"}]}], "}"}]}], ",", 
     RowBox[{"AspectRatio", "->", "1"}], ",", 
     RowBox[{"Axes", "->", "False"}], ",", 
     RowBox[{"GridLines", "->", "None"}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"FrameStyle", "->", 
      RowBox[{"Directive", "[", 
       RowBox[{"Black", ",", 
        RowBox[{"Thickness", "[", "0.002", "]"}], ",", 
        RowBox[{"FontSize", "->", "12"}]}], "]"}]}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{"\"\<p\>\"", ",", "Italic", ",", 
          RowBox[{"FontSize", "->", "14"}]}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<q\>\"", ",", "Italic", ",", 
          RowBox[{"FontSize", "->", "14"}]}], "]"}]}], "}"}]}], ",", 
     RowBox[{"ImageSize", "->", "600"}], ",", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Min", "[", "p", "]"}], ",", 
          RowBox[{"Max", "[", "p", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Min", "[", "q", "]"}], ",", 
          RowBox[{"Max", "[", "q", "]"}]}], "}"}]}], "}"}]}], ",", 
     RowBox[{"PlotRangePadding", "->", 
      RowBox[{"Scaled", "[", "0.05", "]"}]}]}], " ", "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9776578354053087`*^9, 3.977657865885317*^9}, 
