                 RowBox[{"-", "u"}]}]}], "}"}]}], "]"}], "&"}], ",", 
           RowBox[{"{", 
            RowBox[{"{", "1", "}"}], "}"}], ",", "s"}], "]"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
