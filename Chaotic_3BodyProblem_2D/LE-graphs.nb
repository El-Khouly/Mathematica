     RowBox[{"traj1", "=", 
      RowBox[{"trajPoints", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}]}], ";", "\n", 
     RowBox[{"traj2", "=", 
      RowBox[{"trajPoints", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"{", 
          RowBox[{"5", ",", "6"}], "}"}]}], "]"}], "]"}]}], ";", "\n", 
     RowBox[{"traj3", "=", 
      RowBox[{"trajPoints", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"{", 
          RowBox[{"9", ",", "10"}], "}"}]}], "]"}], "]"}]}], ";", "\n", 
     "\[IndentingNewLine]", 
     RowBox[{"trajPlot", "=", 
      RowBox[{"ListLinePlot", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"traj1", ",", "traj2", ",", "traj3"}], "}"}], ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Blue", ",", 
             RowBox[{"Thickness", "[", "0.002", "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"Red", ",", 
             RowBox[{"Thickness", "[", "0.002", "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"Green", ",", 
             RowBox[{"Thickness", "[", "0.002", "]"}]}], "}"}]}], "}"}]}], 
        ",", 
        RowBox[{"Frame", "->", "True"}], ",", 
        RowBox[{"FrameLabel", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
        RowBox[{"PlotLabel", "->", 
         RowBox[{"Style", "[", 
          RowBox[{
           RowBox[{"\"\<Trajectories (first \>\"", "<>", 
            RowBox[{"ToString", "[", 
             RowBox[{"trajSteps", "*", "trajDT"}], "]"}], "<>", 
            "\"\< time units)\>\""}], ",", "14"}], "]"}]}], ",", 
        RowBox[{"AspectRatio", "->", "1"}], ",", 
        RowBox[{"ImageSize", "->", "500"}], ",", 
        RowBox[{"PlotLegends", "->", 
         RowBox[{"{", 
          RowBox[{
          "\"\<Body 1\>\"", ",", "\"\<Body 2\>\"", ",", "\"\<Body 3\>\""}], 
          "}"}]}]}], "]"}]}], ";", "\n", 
     RowBox[{"Print", "[", "trajPlot", "]"}], ";"}], "\n", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"===", "===", "==="}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"9.", " ", "DIAGNOSTICS"}], "===", "===", "==="}], "="}]}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\\n=== Diagnostics ===\>\"", "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Initial energy (kinetic + potential):\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Compute", " ", "initial", " ", "energy"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"r12init", "=", 
     RowBox[{"Norm", "[", 
      RowBox[{"pos2", "-", "pos1"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"r13init", "=", 
     RowBox[{"Norm", "[", 
      RowBox[{"pos3", "-", "pos1"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"r23init", "=", 
     RowBox[{"Norm", "[", 
      RowBox[{"pos3", "-", "pos2"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kinetic", "=", 
     RowBox[{
      RowBox[{"0.5", "*", "m1", "*", 
       RowBox[{
        RowBox[{"Norm", "[", "vel1", "]"}], "^", "2"}]}], "+", 
      RowBox[{"0.5", "*", "m2", "*", 
       RowBox[{
        RowBox[{"Norm", "[", "vel2", "]"}], "^", "2"}]}], "+", 
      RowBox[{"0.5", "*", "m3", "*", 
       RowBox[{
        RowBox[{"Norm", "[", "vel3", "]"}], "^", "2"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"potential", "=", 
     RowBox[{
      RowBox[{"-", "G"}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"m1", "*", 
         RowBox[{"m2", "/", "r12init"}]}], "+", 
        RowBox[{"m1", "*", 
         RowBox[{"m3", "/", "r13init"}]}], "+", 
        RowBox[{"m2", "*", 
         RowBox[{"m3", "/", "r23init"}]}]}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"energyInit", "=", 
     RowBox[{"kinetic", "+", "potential"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<E = \>\"", ",", "energyInit"}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Check", " ", "if", " ", "exponents", " ", "are", " ", "converging"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "lambdaHistory", "]"}], ">", "10"}], ",", 
      RowBox[{
       RowBox[{"lastValues", "=", 
        RowBox[{"Take", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Transpose", "[", "lambdaHistory", "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", 
          RowBox[{"-", "10"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"variation", "=", 
        RowBox[{
         RowBox[{"Max", "[", "lastValues", "]"}], "-", 
         RowBox[{"Min", "[", "lastValues", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{
        "\"\<Variation in last 10 \[Lambda]\:2081 values: \>\"", ",", 
         "variation"}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"variation", "<", 
          RowBox[{"0.01", "*", 
           RowBox[{"Abs", "[", 
            RowBox[{"Mean", "[", "lastValues", "]"}], "]"}]}]}], ",", 
         RowBox[{
         "Print", "[", 
          "\"\<\[Checkmark] \[Lambda]\:2081 appears to be converging\>\"", 
          "]"}], ",", 
         RowBox[{
         "Print", "[", 
          "\"\<\:26a0 \[Lambda]\:2081 still showing significant variation - \
may need more iterations\>\"", "]"}]}], "]"}], ";"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]"}]}]], "Input",
