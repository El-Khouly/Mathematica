       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Average deviation from 0: \>\"", ",", 
         RowBox[{"Mean", "[", 
          RowBox[{"Abs", "[", "sympPairs", "]"}], "]"}]}], "]"}], ";"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", "\[IndentingNewLine]", 
    RowBox[{"(*", 
