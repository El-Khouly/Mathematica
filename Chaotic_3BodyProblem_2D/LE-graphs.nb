   RowBox[{
    RowBox[{"Ttest", "=", "1.0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"stepsize", "=", "0.1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"xT", ",", "PhiT"}], "}"}], "=", 
     RowBox[{"IntVarEq", "[", 
      RowBox[{
      "F", ",", "DPhi", ",", "x", ",", "Phi", ",", "x0", ",", "Phi0", ",", 
       RowBox[{"{", 
        RowBox[{"Ttest", ",", "stepsize"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Position after t = \>\"", ",", "Ttest", ",", "\"\<:\>\""}], 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Body 1: {\>\"", ",", 
      RowBox[{"xT", "[", 
       RowBox[{"[", "1", "]"}], "]"}], ",", "\"\<, \>\"", ",", 
      RowBox[{"xT", "[", 
       RowBox[{"[", "2", "]"}], "]"}], ",", "\"\<}\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Body 2: {\>\"", ",", 
      RowBox[{"xT", "[", 
       RowBox[{"[", "5", "]"}], "]"}], ",", "\"\<, \>\"", ",", 
      RowBox[{"xT", "[", 
       RowBox[{"[", "6", "]"}], "]"}], ",", "\"\<}\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Body 3: {\>\"", ",", 
      RowBox[{"xT", "[", 
       RowBox[{"[", "9", "]"}], "]"}], ",", "\"\<, \>\"", ",", 
      RowBox[{"xT", "[", 
       RowBox[{"[", "10", "]"}], "]"}], ",", "\"\<}\>\""}], "]"}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Quick", " ", "Lyapunov", " ", "test"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"u", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"RandomReal", "[", "]"}], ",", 
       RowBox[{"{", "n", "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"instantLambda", "=", 
     RowBox[{
      RowBox[{"Log", "[", 
       RowBox[{"Norm", "[", 
        RowBox[{"PhiT", ".", "u"}], "]"}], "]"}], "/", "Ttest"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{
     "\"\<Instantaneous \[Lambda] estimate: \>\"", ",", "instantLambda"}], 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"===", "===", "==="}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"6.", " ", "MAIN", " ", "LYAPUNOV", " ", "COMPUTATION"}], "===",
        "===", "==="}], "="}]}], "*)"}], "\n", 
   RowBox[{"(*", "Parameters", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"T", "=", "0.5"}], ";"}], "         ", 
   RowBox[{"(*", 
    RowBox[{"Reorthonormalization", " ", "time"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"stepsize", "=", "0.1"}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{"Integration", " ", "step"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"K", "=", "200"}], ";"}], "         ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Number", " ", "of", " ", "iterations"}], "-", 
     RowBox[{"increased", " ", "for", " ", "better", " ", "convergence"}]}], 
    "*)"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<=== Starting Lyapunov Computation ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{
     "\"\<T = \>\"", ",", "T", ",", "\"\<, dt = \>\"", ",", "stepsize", ",", 
      "\"\<, K = \>\"", ",", "K"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Total integration time: \>\"", ",", 
      RowBox[{"K", "*", "T"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", "Initialize", "*)"}], "\n", 
   RowBox[{
    RowBox[{"PhiT", "=", "Phi0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"xT", "=", "x0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"s", "=", 
     RowBox[{"{", "}"}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Store", " ", "norms", " ", "for", " ", "Gram"}], "-", 
     "Schmidt"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"lambdaHistory", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cumulativeLogs", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"0.0", ",", 
       RowBox[{"{", "n", "}"}]}], "]"}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{"Initialize", " ", "cumulative", " ", "logs"}], "*)"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Monitor", "[", 
     RowBox[{
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"xT", ",", "PhiT"}], "}"}], "=", 
          RowBox[{"IntVarEq", "[", 
           RowBox[{
           "F", ",", "DPhi", ",", "x", ",", "Phi", ",", "xT", ",", "PhiT", 
            ",", 
            RowBox[{"{", 
             RowBox[{"T", ",", "stepsize"}], "}"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"Gram", "-", 
           RowBox[{"Schmidt", " ", "reorthonormalization"}]}], "*)"}], 
         RowBox[{"W", "=", 
          RowBox[{"GramSchm", "[", "PhiT", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"norms", "=", 
          RowBox[{"Map", "[", 
           RowBox[{"Norm", ",", "W"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"Store", " ", "norms"}], "*)"}], 
         RowBox[{"s", "=", 
          RowBox[{"Append", "[", 
           RowBox[{"s", ",", "norms"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"Reorthonormalize", " ", "PhiT"}], "*)"}], 
         RowBox[{"PhiT", "=", 
          RowBox[{"W", "/", "norms"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "Update", " ", "cumulative", " ", "logs", " ", "and", " ", 
           "compute", " ", "current", " ", "LCEs"}], "*)"}], 
         RowBox[{"cumulativeLogs", "=", 
          RowBox[{"cumulativeLogs", "+", 
           RowBox[{"Log", "[", "norms", "]"}]}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"currentLCEs", "=", 
          RowBox[{"cumulativeLogs", "/", 
           RowBox[{"(", 
            RowBox[{"i", "*", "T"}], ")"}]}]}], ";", 
         RowBox[{"(*", 
          RowBox[{
          "i", " ", "iterations", " ", "of", " ", "length", " ", "T"}], 
          "*)"}], 
         RowBox[{"AppendTo", "[", 
          RowBox[{"lambdaHistory", ",", "currentLCEs"}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", "Progress", "*)"}], 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{"i", ",", "20"}], "]"}], "==", "0"}], ",", 
           RowBox[{"Print", "[", 
            RowBox[{
            "\"\<Iteration \>\"", ",", "i", ",", "\"\</\>\"", ",", "K", ",", 
             "\"\<  \[Lambda]\:2081 = \>\"", ",", 
             RowBox[{"currentLCEs", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ",", 
             "\"\<  \[Lambda]\:2082 = \>\"", ",", 
             RowBox[{"currentLCEs", "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", "\"\<  Max = \>\"", ",", 
             RowBox[{"Max", "[", "currentLCEs", "]"}]}], "]"}]}], "]"}], 
         ";"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "K"}], "}"}]}], "]"}], ",", 
      RowBox[{"ProgressIndicator", "[", 
       RowBox[{"i", ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "K"}], "}"}]}], "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<=== Computation Complete ===\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
