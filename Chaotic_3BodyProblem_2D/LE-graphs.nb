            RowBox[{"y", "->", "y0"}], "]"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"k2", "=", 
        RowBox[{"dt", " ", 
         RowBox[{"N", "[", 
          RowBox[{"f", "/.", " ", 
           RowBox[{"Thread", "[", 
            RowBox[{"y", "->", 
             RowBox[{"y0", "+", 
              RowBox[{"k1", "/", "2"}]}]}], "]"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"k3", "=", 
        RowBox[{"dt", " ", 
         RowBox[{"N", "[", 
          RowBox[{"f", "/.", " ", 
           RowBox[{"Thread", "[", 
            RowBox[{"y", "->", 
             RowBox[{"y0", "+", 
              RowBox[{"k2", "/", "2"}]}]}], "]"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"k4", "=", 
        RowBox[{"dt", " ", 
         RowBox[{"N", "[", 
          RowBox[{"f", "/.", " ", 
           RowBox[{"Thread", "[", 
            RowBox[{"y", "->", 
             RowBox[{"y0", "+", "k3"}]}], "]"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
