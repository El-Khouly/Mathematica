       RowBox[{"\[Lambda]_", 
        RowBox[{"{", 
         RowBox[{"n", "+", "1", "-", "i"}], "}"}], " ", "should", " ", 
        RowBox[{"be", "~", "0"}]}]}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== Symplectic Symmetry Check ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"EvenQ", "[", "n", "]"}], ",", 
