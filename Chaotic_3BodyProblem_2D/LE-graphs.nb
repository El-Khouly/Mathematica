       RowBox[{"PlotLabel", "->", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<Final Lyapunov Spectrum\>\"", ",", "16", ",", "Bold"}], 
         "]"}]}], ",", 
       RowBox[{"GridLines", "->", "Automatic"}], ",", 
       RowBox[{"ImageSize", "->", "600"}], ",", 
       RowBox[{"ColorFunction", "->", 
        RowBox[{"Function", "[", 
         RowBox[{
          RowBox[{"{", "height", "}"}], ",", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"height", ">", "0.001"}], ",", 
            RowBox[{"RGBColor", "[", 
             RowBox[{"0.9", ",", "0.2", ",", "0.2"}], "]"}], ",", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"height", "<", 
               RowBox[{"-", "0.001"}]}], ",", 
              RowBox[{"RGBColor", "[", 
               RowBox[{"0.2", ",", "0.2", ",", "0.9"}], "]"}], ",", 
              RowBox[{"RGBColor", "[", 
               RowBox[{"0.5", ",", "0.5", ",", "0.5"}], "]"}]}], "]"}]}], 
           "]"}]}], "]"}]}], ",", 
       RowBox[{"ChartStyle", "->", "\"\<TemperatureMap\>\""}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "spectrumPlot", "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"8.4", " ", "Symplectic", " ", "symmetry", " ", 
     RowBox[{"check", ":", 
      RowBox[{"\[Lambda]_i", "+", 
       RowBox[{"\[Lambda]_", 
        RowBox[{"{", 
         RowBox[{"n", "+", "1", "-", "i"}], "}"}], " ", "should", " ", 
        RowBox[{"be", "~", "0"}]}]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== Symplectic Symmetry Check ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"EvenQ", "[", "n", "]"}], ",", 
      RowBox[{
       RowBox[{"sympPairs", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"finalLCEs", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "+", 
           RowBox[{"finalLCEs", "[", 
            RowBox[{"[", 
             RowBox[{"n", "+", "1", "-", "i"}], "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", 
            RowBox[{"n", "/", "2"}]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
       "Print", "[", 
        "\"\<\[Lambda]_i + \[Lambda]_{n+1-i} (should be near 0):\>\"", "]"}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"i", "=", "1"}], ",", 
         RowBox[{"i", "<=", 
          RowBox[{"Length", "[", "sympPairs", "]"}]}], ",", 
         RowBox[{"i", "++"}], ",", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<Pair \>\"", ",", "i", ",", "\"\<: \>\"", ",", 
           RowBox[{"sympPairs", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Average deviation from 0: \>\"", ",", 
         RowBox[{"Mean", "[", 
          RowBox[{"Abs", "[", "sympPairs", "]"}], "]"}]}], "]"}], ";"}]}], 
     "]"}], ";"}], "\n", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"8.5", " ", "Trajectory", " ", "plot", " ", 
      RowBox[{"(", "optional", ")"}]}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
     "Print", "[", "\"\<\\n=== Optional: Short Trajectory Plot ===\>\"", 
      "]"}], ";", "\n", 
     RowBox[{"trajSteps", "=", "1000"}], ";", "\n", 
     RowBox[{"trajDT", "=", "0.01"}], ";", "\n", 
     RowBox[{"trajPoints", "=", 
      RowBox[{"NestList", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"RKStep", "[", 
          RowBox[{"F", ",", "x", ",", "#", ",", "trajDT"}], "]"}], "&"}], ",",
         "x0", ",", "trajSteps"}], "]"}]}], ";", "\n", 
     RowBox[{"traj1", "=", 
      RowBox[{"trajPoints", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}]}], ";", "\n", 
     RowBox[{"traj2", "=", 
      RowBox[{"trajPoints", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"{", 
          RowBox[{"5", ",", "6"}], "}"}]}], "]"}], "]"}]}], ";", "\n", 
     RowBox[{"traj3", "=", 
      RowBox[{"trajPoints", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"{", 
          RowBox[{"9", ",", "10"}], "}"}]}], "]"}], "]"}]}], ";", "\n", 
     "\[IndentingNewLine]", 
     RowBox[{"trajPlot", "=", 
      RowBox[{"ListLinePlot", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"traj1", ",", "traj2", ",", "traj3"}], "}"}], ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Blue", ",", 
             RowBox[{"Thickness", "[", "0.002", "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"Red", ",", 
             RowBox[{"Thickness", "[", "0.002", "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"Green", ",", 
             RowBox[{"Thickness", "[", "0.002", "]"}]}], "}"}]}], "}"}]}], 
        ",", 
        RowBox[{"Frame", "->", "True"}], ",", 
        RowBox[{"FrameLabel", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
        RowBox[{"PlotLabel", "->", 
         RowBox[{"Style", "[", 
          RowBox[{
           RowBox[{"\"\<Trajectories (first \>\"", "<>", 
            RowBox[{"ToString", "[", 
             RowBox[{"trajSteps", "*", "trajDT"}], "]"}], "<>", 
            "\"\< time units)\>\""}], ",", "14"}], "]"}]}], ",", 
        RowBox[{"AspectRatio", "->", "1"}], ",", 
        RowBox[{"ImageSize", "->", "500"}], ",", 
        RowBox[{"PlotLegends", "->", 
         RowBox[{"{", 
          RowBox[{
          "\"\<Body 1\>\"", ",", "\"\<Body 2\>\"", ",", "\"\<Body 3\>\""}], 
          "}"}]}]}], "]"}]}], ";", "\n", 
     RowBox[{"Print", "[", "trajPlot", "]"}], ";"}], "\n", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"===", "===", "==="}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"9.", " ", "DIAGNOSTICS"}], "===", "===", "==="}], "="}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\\n=== Diagnostics ===\>\"", "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Initial energy (kinetic + potential):\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"Compute", " ", "initial", " ", "energy"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"r12init", "=", 
     RowBox[{"Norm", "[", 
      RowBox[{"pos2", "-", "pos1"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"r13init", "=", 
     RowBox[{"Norm", "[", 
      RowBox[{"pos3", "-", "pos1"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"r23init", "=", 
     RowBox[{"Norm", "[", 
      RowBox[{"pos3", "-", "pos2"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kinetic", "=", 
     RowBox[{
      RowBox[{"0.5", "*", "m1", "*", 
       RowBox[{
        RowBox[{"Norm", "[", "vel1", "]"}], "^", "2"}]}], "+", 
      RowBox[{"0.5", "*", "m2", "*", 
       RowBox[{
        RowBox[{"Norm", "[", "vel2", "]"}], "^", "2"}]}], "+", 
      RowBox[{"0.5", "*", "m3", "*", 
       RowBox[{
        RowBox[{"Norm", "[", "vel3", "]"}], "^", "2"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"potential", "=", 
     RowBox[{
      RowBox[{"-", "G"}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"m1", "*", 
         RowBox[{"m2", "/", "r12init"}]}], "+", 
        RowBox[{"m1", "*", 
         RowBox[{"m3", "/", "r13init"}]}], "+", 
        RowBox[{"m2", "*", 
         RowBox[{"m3", "/", "r23init"}]}]}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"energyInit", "=", 
     RowBox[{"kinetic", "+", "potential"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<E = \>\"", ",", "energyInit"}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Check", " ", "if", " ", "exponents", " ", "are", " ", "converging"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "lambdaHistory", "]"}], ">", "10"}], ",", 
      RowBox[{
       RowBox[{"lastValues", "=", 
        RowBox[{"Take", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Transpose", "[", "lambdaHistory", "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", 
          RowBox[{"-", "10"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"variation", "=", 
        RowBox[{
         RowBox[{"Max", "[", "lastValues", "]"}], "-", 
         RowBox[{"Min", "[", "lastValues", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{
        "\"\<Variation in last 10 \[Lambda]\:2081 values: \>\"", ",", 
         "variation"}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"variation", "<", 
          RowBox[{"0.01", "*", 
           RowBox[{"Abs", "[", 
            RowBox[{"Mean", "[", "lastValues", "]"}], "]"}]}]}], ",", 
         RowBox[{
         "Print", "[", 
          "\"\<\[Checkmark] \[Lambda]\:2081 appears to be converging\>\"", 
          "]"}], ",", 
         RowBox[{
         "Print", "[", 
          "\"\<\:26a0 \[Lambda]\:2081 still showing significant variation - \
may need more iterations\>\"", "]"}]}], "]"}], ";"}]}], "]"}], 
    ";"}]}]}]], "Input",
