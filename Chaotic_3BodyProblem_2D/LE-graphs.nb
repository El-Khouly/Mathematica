Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", "===", "==="}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"THREE", "-", 
       RowBox[{"BODY", " ", "LYAPUNOV", " ", "EXPONENTS"}]}], "===", "===", 
      "==="}], "="}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"===", "===", "==="}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"1.", " ", "UTILITY", " ", "FUNCTIONS"}], "===", "===", 
       "==="}], "="}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"JacobianMtx", "[", 
     RowBox[{"funs_List", ",", "vars_List"}], "]"}], ":=", 
    RowBox[{"Outer", "[", 
     RowBox[{"D", ",", "funs", ",", "vars"}], "]"}]}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
    RowBox[{"RKStep", "[", 
     RowBox[{"f_", ",", "y_", ",", "y0_", ",", "dt_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"k1", ",", "k2", ",", "k3", ",", "k4"}], "}"}], ",", 
      RowBox[{
       RowBox[{"k1", "=", 
        RowBox[{"dt", " ", 
         RowBox[{"N", "[", 
          RowBox[{"f", "/.", " ", 
           RowBox[{"Thread", "[", 
            RowBox[{"y", "->", "y0"}], "]"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"k2", "=", 
        RowBox[{"dt", " ", 
         RowBox[{"N", "[", 
          RowBox[{"f", "/.", " ", 
           RowBox[{"Thread", "[", 
            RowBox[{"y", "->", 
             RowBox[{"y0", "+", 
              RowBox[{"k1", "/", "2"}]}]}], "]"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"k3", "=", 
        RowBox[{"dt", " ", 
         RowBox[{"N", "[", 
          RowBox[{"f", "/.", " ", 
           RowBox[{"Thread", "[", 
            RowBox[{"y", "->", 
             RowBox[{"y0", "+", 
              RowBox[{"k2", "/", "2"}]}]}], "]"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"k4", "=", 
        RowBox[{"dt", " ", 
         RowBox[{"N", "[", 
          RowBox[{"f", "/.", " ", 
           RowBox[{"Thread", "[", 
            RowBox[{"y", "->", 
             RowBox[{"y0", "+", "k3"}]}], "]"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"y0", "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"k1", "+", 
           RowBox[{"2", " ", "k2"}], "+", 
           RowBox[{"2", " ", "k3"}], "+", "k4"}], ")"}], "/", "6"}]}]}]}], 
     "]"}]}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"RKPoint", "[", 
     RowBox[{"f_List", ",", "y_List", ",", "y0_List", ",", 
      RowBox[{"{", 
       RowBox[{"t1_", ",", "dt_"}], "}"}]}], "]"}], ":=", 
    RowBox[{"Nest", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"RKStep", "[", 
        RowBox[{"f", ",", "y", ",", "#", ",", 
         RowBox[{"N", "[", "dt", "]"}]}], "]"}], "&"}], ",", 
      RowBox[{"N", "[", "y0", "]"}], ",", 
      RowBox[{"Round", "[", 
       RowBox[{"N", "[", 
        RowBox[{"t1", "/", "dt"}], "]"}], "]"}]}], "]"}]}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"IntVarEq", "[", 
     RowBox[{
     "F_List", ",", "DPhi_List", ",", "x_List", ",", "Phi_List", ",", 
      "x0_List", ",", "Phi0_List", ",", 
      RowBox[{"{", 
