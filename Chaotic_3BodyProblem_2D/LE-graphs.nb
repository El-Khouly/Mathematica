   "\[IndentingNewLine]", 
   RowBox[{"(*", "Initialize", "*)"}], "\n", 
   RowBox[{
    RowBox[{"PhiT", "=", "Phi0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"xT", "=", "x0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"s", "=", 
     RowBox[{"{", "}"}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Store", " ", "norms", " ", "for", " ", "Gram"}], "-", 
     "Schmidt"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"lambdaHistory", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cumulativeLogs", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"0.0", ",", 
       RowBox[{"{", "n", "}"}]}], "]"}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{"Initialize", " ", "cumulative", " ", "logs"}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Monitor", "[", 
     RowBox[{
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"xT", ",", "PhiT"}], "}"}], "=", 
          RowBox[{"IntVarEq", "[", 
           RowBox[{
           "F", ",", "DPhi", ",", "x", ",", "Phi", ",", "xT", ",", "PhiT", 
            ",", 
            RowBox[{"{", 
             RowBox[{"T", ",", "stepsize"}], "}"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"Gram", "-", 
           RowBox[{"Schmidt", " ", "reorthonormalization"}]}], "*)"}], 
         RowBox[{"W", "=", 
          RowBox[{"GramSchm", "[", "PhiT", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"norms", "=", 
          RowBox[{"Map", "[", 
           RowBox[{"Norm", ",", "W"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"Store", " ", "norms"}], "*)"}], 
         RowBox[{"s", "=", 
          RowBox[{"Append", "[", 
           RowBox[{"s", ",", "norms"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"Reorthonormalize", " ", "PhiT"}], "*)"}], 
         RowBox[{"PhiT", "=", 
          RowBox[{"W", "/", "norms"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "Update", " ", "cumulative", " ", "logs", " ", "and", " ", 
           "compute", " ", "current", " ", "LCEs"}], "*)"}], 
         RowBox[{"cumulativeLogs", "=", 
          RowBox[{"cumulativeLogs", "+", 
           RowBox[{"Log", "[", "norms", "]"}]}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"currentLCEs", "=", 
          RowBox[{"cumulativeLogs", "/", 
           RowBox[{"(", 
            RowBox[{"i", "*", "T"}], ")"}]}]}], ";", 
         RowBox[{"(*", 
          RowBox[{
          "i", " ", "iterations", " ", "of", " ", "length", " ", "T"}], 
          "*)"}], 
         RowBox[{"AppendTo", "[", 
          RowBox[{"lambdaHistory", ",", "currentLCEs"}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", "Progress", "*)"}], 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{"i", ",", "20"}], "]"}], "==", "0"}], ",", 
           RowBox[{"Print", "[", 
            RowBox[{
            "\"\<Iteration \>\"", ",", "i", ",", "\"\</\>\"", ",", "K", ",", 
             "\"\<  \[Lambda]\:2081 = \>\"", ",", 
             RowBox[{"currentLCEs", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ",", 
             "\"\<  \[Lambda]\:2082 = \>\"", ",", 
             RowBox[{"currentLCEs", "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", "\"\<  Max = \>\"", ",", 
             RowBox[{"Max", "[", "currentLCEs", "]"}]}], "]"}]}], "]"}], 
         ";"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "K"}], "}"}]}], "]"}], ",", 
      RowBox[{"ProgressIndicator", "[", 
       RowBox[{"i", ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "K"}], "}"}]}], "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
